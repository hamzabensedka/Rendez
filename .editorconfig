# EditorConfig: https://editorconfig.org
# Use one consistent line ending (LF) to avoid "LF will be replaced by CRLF" git warnings
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,ts,tsx,json,md,yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
