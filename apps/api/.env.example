# Copy this file to .env and fill in real values. Never commit .env or real secrets.

# Database (e.g. Supabase: Project Settings → Database → Connection string URI)
# If your password contains @, #, or other special chars, encode them: @ → %40, # → %23
# Production (e.g. Supabase + PgBouncer): consider tuning pool size in the URL, e.g.
# ?connection_limit=5&pool_timeout=20
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# JWT: generate strong random secrets (e.g. openssl rand -base64 32). Use different values per environment.
JWT_ACCESS_SECRET="replace-with-at-least-16-char-random-string"
JWT_REFRESH_SECRET="replace-with-another-32-char-random-string"

# Optional
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"
PORT=3000
NODE_ENV=development

# CORS: comma-separated list of allowed browser origins (no spaces). Omit to default to http://localhost:19006
# ALLOWED_ORIGINS=http://localhost:19006,https://app.example.com

# Public app URL (used by config endpoint and deep links). Optional; defaults in code if unset.
# APP_URL=https://your-app.example.com

# Optional: shared Redis for multi-instance caching and Nominatim coordination (omit = in-memory fallback)
# REDIS_URL=redis://localhost:6379

# Optional: contact email for Nominatim User-Agent (usage policy)
# NOMINATIM_EMAIL=you@example.com

# Optional: Nominatim country filter (comma-separated ISO codes). Default: fr (France only for address suggest)
# PLACES_COUNTRY_CODES=fr
