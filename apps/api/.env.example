# Copy this file to .env and fill in real values. Never commit .env or real secrets.

# Database (e.g. Supabase: Project Settings → Database → Connection string URI)
# If your password contains @, #, or other special chars, encode them: @ → %40, # → %23
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# JWT: generate strong random secrets (e.g. openssl rand -base64 32). Use different values per environment.
JWT_ACCESS_SECRET="replace-with-at-least-16-char-random-string"
JWT_REFRESH_SECRET="replace-with-another-32-char-random-string"

# Optional
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"
PORT=3000
NODE_ENV=development
